<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp">

    <!-- ── Camera preview (Left side) ────────────────────────────────────── -->
    <androidx.camera.view.PreviewView
        android:id="@+id/view_finder"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.6" />

    <!-- ── Right side controls ────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideline"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/header_acquisition"
            android:textColor="@color/tscm_primary"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <!-- Thumbnail row -->
        <LinearLayout
            android:id="@+id/thumbnail_row"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:strokeColor="@color/outline"
                app:cardBackgroundColor="@color/surface_variant">
                <ImageView
                    android:id="@+id/img_before_thumb"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:visibility="invisible" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:strokeColor="@color/outline"
                app:cardBackgroundColor="@color/surface_variant">
                <ImageView
                    android:id="@+id/img_after_thumb"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:visibility="invisible" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">
            <Button
                android:id="@+id/btn_capture_before"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_scan_reference"
                android:textSize="10sp"
                style="@style/Widget.Tscm.Button.Outlined"
                android:layout_marginEnd="4dp" />
            <Button
                android:id="@+id/btn_capture_after"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_scan_current"
                android:textSize="10sp"
                style="@style/Widget.Tscm.Button.Outlined"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp">

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_strip_metadata"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_strip_metadata"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:checked="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button
                    android:id="@+id/btn_upload_before"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_import"
                    android:textSize="10sp"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_marginEnd="4dp" />
                <Button
                    android:id="@+id/btn_upload_after"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_import"
                    android:textSize="10sp"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_marginStart="4dp" />
            </LinearLayout>
        </LinearLayout>


        <!-- Shutter -->
        <Button
            android:id="@+id/btn_shutter"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:backgroundTint="@color/white" />

    </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
