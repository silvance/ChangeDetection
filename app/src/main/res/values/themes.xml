<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.TscmChangeDetection" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/tscm_primary</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/tscm_primary_dark</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="colorSurface">@color/black</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOutline">@color/outline</item>
    </style>

    <style name="Widget.Tscm.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textSize">12sp</item>
        <item name="strokeColor">@color/tscm_primary</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.Tscm.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textSize">12sp</item>
        <item name="backgroundTint">@color/tscm_primary</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="Widget.Tscm.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_variant</item>
        <item name="cardCornerRadius">8dp</item>
    </style>

</resources>
