<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Header -->
        <TextView
            android:id="@+id/txt_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:text="@string/header_comparison"
            android:textColor="@color/tscm_primary"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:textSize="14sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Metrics Display (from Desktop app) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/metrics_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="4dp"
            app:cardBackgroundColor="#33000000"
            app:cardCornerRadius="4dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/txt_header">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/val_changed_pct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/tscm_primary"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_changed_area"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:letterSpacing="0.1" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="24dp" android:background="@color/outline" android:layout_gravity="center_vertical" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/val_changed_px"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/tscm_primary"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_pixel_count"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:letterSpacing="0.1" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="24dp" android:background="@color/outline" android:layout_gravity="center_vertical" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/val_regions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/tscm_primary"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_regions"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:letterSpacing="0.1" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Mode Selector Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mode_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:cardBackgroundColor="@color/surface_variant"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/outline"
            app:layout_constraintTop_toBottomOf="@id/metrics_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">

                <Button
                    android:id="@+id/btn_mode_slider"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/btn_slider"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/btn_mode_toggle"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/btn_toggle"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/btn_mode_auto"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/btn_auto"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:textSize="11sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Main View Area -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="12dp"
            app:cardBackgroundColor="@color/surface_variant"
            app:cardCornerRadius="8dp"
            app:strokeColor="@color/outline"
            app:layout_constraintTop_toBottomOf="@id/mode_card"
            app:layout_constraintBottom_toTopOf="@id/bottom_controls"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                <com.tscm.changedetection.SplitImageView
                    android:id="@+id/split_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <FrameLayout
                    android:id="@+id/toggle_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone">
                    <ImageView
                        android:id="@+id/toggle_image_view"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside" />
                    <TextView
                        android:id="@+id/txt_toggle_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:padding="8dp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:background="#88000000" />
                </FrameLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Contextual Bottom Controls -->
        <LinearLayout
            android:id="@+id/bottom_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Slider Orientation -->
            <LinearLayout
                android:id="@+id/orientation_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">
                <Button
                    android:id="@+id/btn_orient_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_horizontal"
                    style="@style/Widget.Tscm.Button.Outlined"
                    android:layout_marginEnd="8dp" />
                <Button
                    android:id="@+id/btn_orient_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_vertical"
                    style="@style/Widget.Tscm.Button.Outlined" />
            </LinearLayout>

            <!-- Toggle Controls -->
            <LinearLayout
                android:id="@+id/toggle_buttons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:visibility="gone">
                <Button
                    android:id="@+id/btn_toggle_before"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_before"
                    style="@style/Widget.Tscm.Button.Outlined" />
                <Button
                    android:id="@+id/btn_toggle_swap"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:text="↔"
                    style="@style/Widget.Tscm.Button.Outlined"
                    android:layout_marginHorizontal="8dp" />
                <Button
                    android:id="@+id/btn_toggle_after"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_after"
                    style="@style/Widget.Tscm.Button.Outlined" />
            </LinearLayout>

            <!-- Auto Controls -->
            <LinearLayout
                android:id="@+id/auto_controls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <TextView
                    android:id="@+id/lbl_flicker_speed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:text="@string/label_flicker_interval"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="4dp" />
                <SeekBar
                    android:id="@+id/seek_flicker_speed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
