<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <!-- ── Camera preview ────────────────────────────────────────────────── -->
    <androidx.camera.view.PreviewView
        android:id="@+id/view_finder"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/control_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Header ────────────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/txt_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/header_acquisition"
        android:textColor="@color/tscm_primary"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ── Content Area (When camera is off) ────────────────────────────── -->
    <FrameLayout
        android:id="@+id/empty_state_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/txt_header"
        app:layout_constraintBottom_toTopOf="@id/control_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/img_logo_background"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:src="@drawable/tscm_eye"
            android:alpha="0.15"
            android:scaleType="centerInside" />

        <LinearLayout
            android:id="@+id/thumbnail_row"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="2"
            android:padding="16dp">

            <!-- BEFORE -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="8dp"
                app:strokeColor="@color/outline"
                app:cardBackgroundColor="@color/surface_variant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">
                    <TextView
                        android:text="@string/label_reference_before"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="8dp"
                        android:background="#33000000" />
                    <ImageView
                        android:id="@+id/img_before_thumb"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:visibility="invisible" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AFTER -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="8dp"
                app:strokeColor="@color/outline"
                app:cardBackgroundColor="@color/surface_variant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">
                    <TextView
                        android:text="@string/label_current_after"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="8dp"
                        android:background="#33000000" />
                    <ImageView
                        android:id="@+id/img_after_thumb"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:visibility="invisible" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </FrameLayout>

    <!-- ── Control Panel ────────────────────────────────────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/control_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface_variant"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        android:layout_margin="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_capture_before"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/btn_scan_reference"
                    style="@style/Widget.Tscm.Button.Outlined" />

                <Button
                    android:id="@+id/btn_capture_after"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_scan_current"
                    style="@style/Widget.Tscm.Button.Outlined" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_strip_metadata"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_strip_metadata"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:checked="true" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_upload_before"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/btn_import"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:textSize="10sp"
                    android:textColor="@color/tscm_primary"
                    app:icon="@android:drawable/ic_menu_upload"
                    app:iconSize="14dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_upload_after"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/btn_import"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:textSize="10sp"
                    android:textColor="@color/tscm_primary"
                    app:icon="@android:drawable/ic_menu_upload"
                    app:iconSize="14dp" />

            </LinearLayout>

            <Button
                android:id="@+id/btn_shutter"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:backgroundTint="@color/white"
                app:shapeAppearanceOverlay="@style/Widget.Material3.CircularProgressIndicator" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
